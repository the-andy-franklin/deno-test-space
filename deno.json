{
	"tasks": {
		"dev": "deno run --watch main.ts"
	},
	"compilerOptions": {
		"experimentalDecorators": true
	},
	"fmt": {
		"semiColons": true,
		"lineWidth": 9999,
		"useTabs": true,
		"indentWidth": 4
	},
	"lint": {
		"rules": {
			"exclude": [
				"no-unused-vars",
				"no-inferrable-types"
			]
		}
	}
}
